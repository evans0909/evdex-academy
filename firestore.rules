rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read access to universities for all users
    match /universities/{universityId} {
      allow read: if true;
      allow write: if request.auth != null && 
        request.auth.token.email == "bwalyaevans09@gmail.com";
    }

    // User profile security rules
    match /users/{userId} {
      // Users can read their own profile
      allow read: if request.auth != null && 
        request.auth.uid == userId;
      
      // Users can create their own profile during registration
      allow create: if request.auth != null && 
        request.auth.uid == userId &&
        request.resource.data.uid == request.auth.uid;
      
      // Users can update their own profile
      allow update: if request.auth != null && 
        request.auth.uid == userId;
      
      // Only admin can delete users
      allow delete: if request.auth != null && 
        request.auth.token.email == "bwalyaevans09@gmail.com";
    }

    // Admin-specific rules - only bwalyaevans09@gmail.com can modify
    match /admin/{document=**} {
      allow read, write: if request.auth != null && 
        request.auth.token.email == "bwalyaevans09@gmail.com";
    }

    // Materials access control
    match /materials/{materialId} {
      // All authenticated users can read materials
      allow read: if request.auth != null;
      
      // Only admin can write materials
      allow write: if request.auth != null && 
        request.auth.token.email == "bwalyaevans09@gmail.com";
    }

    // User-specific data (like settings, bookmarks)
    match /userData/{userId}/{collection}/{document} {
      allow read: if request.auth != null && 
        request.auth.uid == userId;
      
      allow write: if request.auth != null && 
        request.auth.uid == userId;
    }

    // System-wide settings - admin only
    match /system/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        request.auth.token.email == "bwalyaevans09@gmail.com";
    }

    // Generic fallback rules
    match /{document=**} {
      // Deny all other operations by default
      allow read, write: if false;
    }
  }
}